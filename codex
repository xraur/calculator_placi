# ==============================================================================
# GENEREAZA sea_index.js PENTRU CAUTARE SETUP-URI SEA
# Ruleaza: Click dreapta pe fisier -> Run with PowerShell
# NECESITA: Microsoft Excel instalat (pentru citirea .xls/.xlsx/.xlsm)
# ==============================================================================

$ErrorActionPreference = "Stop"

$OutputJs   = "sea_index.js"
$RootFolder = $PSScriptRoot

# ==============================================================================
# CONFIGURARE - MODIFICI DOAR AICI
# ==============================================================================

$Config = @{
    RafturiFamilii = @{
        # "Bit Box" = @("MODULU 1", "A 2", "A 6")
        # "Nikko"   = @("MODULU 5", "B 5")
        # "P5"      = @("C 1")
    }

    RafturiPN = @{
        # "SEAH-Z701440-02" = @("MODULU 5")
        # "SEA4-WHOLM"      = @("A 4")
    }

    CategoriiPN = @(
        # @{ Categorie = "Cutii";      IncepeCu = @("SEA4-WHOLM") }
        # @{ Categorie = "Bureti";     IncepeCu = @("SEA4-SPG") }
        # @{ Categorie = "Placi";      IncepeCu = @("SEA4-NNZ8", "F-09-0118_C1") }
        # @{ Categorie = "Componente"; IncepeCu = @("SEA4-HRB") }
    )
}

# ==============================================================================
# FUNCTII
# ==============================================================================

function Get-RelativePath {
    param(
        [string]$BasePath,
        [string]$FullPath
    )

    if ([string]::IsNullOrWhiteSpace($FullPath)) {
        return ""
    }

    if ([string]::IsNullOrWhiteSpace($BasePath)) {
        return ($FullPath -replace '\\', '/')
    }

    if ($FullPath.StartsWith($BasePath, [System.StringComparison]::OrdinalIgnoreCase)) {
        $relative = $FullPath.Substring($BasePath.Length).TrimStart('\', '/')
        return ($relative -replace '\\', '/')
    }

    return ($FullPath -replace '\\', '/')
}

function Get-FolderPathFromFileRelativePath {
    param([string]$RelativeFilePath)

    if ([string]::IsNullOrWhiteSpace($RelativeFilePath)) {
        return ""
    }

    $dir = Split-Path -Path $RelativeFilePath -Parent

    if ([string]::IsNullOrWhiteSpace($dir)) {
        return ""
    }

    return ($dir -replace '\\', '/')
}

function Get-FamilyFromRelativePath {
    param([string]$RelativeFolderPath)

    if ([string]::IsNullOrWhiteSpace($RelativeFolderPath)) {
        return "Necunoscut"
    }

    $parts = @(
        ($RelativeFolderPath -split '/')
        | Where-Object { -not [string]::IsNullOrWhiteSpace($_) }
        | ForEach-Object { ([string]$_).Trim() }
    )

    if ($parts.Count -gt 0) {
        return $parts[0]
    }

    return "Necunoscut"
}

function Get-TypeFromFilename {
    param([string]$Filename)

    $lower = ([string]$Filename).ToLower()

    if ($lower -match 'assy|asamblare|assembly') { return "Assy" }
    if ($lower -match 'prep|preparare') { return "Prep" }
    if ($lower -match 'hand.?load|(^|[^a-z])hl([^a-z]|$)') { return "Handload" }
    if ($lower -match 'hand.?solder|soldering|(^|[^a-z])hs([^a-z]|$)') { return "Hand Soldering" }
    if ($lower -match 'press.?fit|(^|[^a-z])pf([^a-z]|$)') { return "Pressfit" }
    if ($lower -match 'pack|product.?pack') { return "Pack" }
    if ($lower -match 'label') { return "Label" }
    if ($lower -match 'light.?guide') { return "Light Guide" }

    return "Setup"
}

function Get-Shelf {
    param(
        [string]$PN,
        [string]$Family
    )

    foreach ($key in $Config.RafturiPN.Keys) {
        if (-not [string]::IsNullOrWhiteSpace($PN) -and $PN.StartsWith($key, [System.StringComparison]::OrdinalIgnoreCase)) {
            return ($Config.RafturiPN[$key] -join ", ")
        }
    }

    foreach ($key in $Config.RafturiFamilii.Keys) {
        if ($Family -eq $key) {
            return ($Config.RafturiFamilii[$key] -join ", ")
        }
    }

    return "?"
}

function Test-PNRule {
    param(
        [string]$PN,
        [string[]]$Rules
    )

    foreach ($rule in $Rules) {
        if (-not [string]::IsNullOrWhiteSpace($rule) -and $PN.StartsWith($rule, [System.StringComparison]::OrdinalIgnoreCase)) {
            return $true
        }
    }

    return $false
}

function Get-Category {
    param([string]$PN)

    foreach ($rule in $Config.CategoriiPN) {
        if ($rule.IncepeCu -and (Test-PNRule -PN $PN -Rules $rule.IncepeCu)) {
            return $rule.Categorie
        }
    }

    return "Necategorisit"
}

function Normalize-PN {
    param([string]$PN)

    if ([string]::IsNullOrWhiteSpace($PN)) {
        return ""
    }

    $value = $PN.Trim().ToUpperInvariant()
    $value = $value -replace '\.(XLS|XLSX|XLSM)$', ''
    $value = $value -replace '[-_\s]+$', ''

    return $value
}

function Get-PNsFromText {
    param([string]$Text)

    $results = New-Object System.Collections.Generic.List[string]

    if ([string]::IsNullOrWhiteSpace($Text)) {
        return @()
    }

    $patterns = @(
        'SEA[0-9H]*-[A-Z0-9]+(?:[-_][A-Z0-9]+)*',
        'F-09-0118(?:[-_][A-Z0-9]+)*(?:\s+[A-Z0-9]+){0,3}'
    )

    foreach ($pattern in $patterns) {
        $matches = [regex]::Matches($Text.ToUpperInvariant(), $pattern, [System.Text.RegularExpressions.RegexOptions]::IgnoreCase)

        foreach ($match in $matches) {
            $pn = Normalize-PN -PN $match.Value

            if (-not [string]::IsNullOrWhiteSpace($pn) -and $pn.Length -ge 8 -and -not $results.Contains($pn)) {
                [void]$results.Add($pn)
            }
        }
    }

    return $results.ToArray()
}

function Get-ExcelPNHits {
    param([string]$FilePath)

    $excel = $null
    $workbook = $null
    $sheet = $null
    $usedRange = $null

    $hits = New-Object System.Collections.Generic.List[object]

    try {
        $excel = New-Object -ComObject Excel.Application
        $excel.Visible = $false
        $excel.DisplayAlerts = $false

        $workbook = $excel.Workbooks.Open($FilePath, $false, $true)
        $sheet = $workbook.Sheets.Item(1)
        $usedRange = $sheet.UsedRange

        $rowCount = $usedRange.Rows.Count
        $colCount = $usedRange.Columns.Count

        for ($r = 1; $r -le $rowCount; $r++) {
            for ($c = 1; $c -le $colCount; $c++) {
                $cell = $usedRange.Item($r, $c)
                $text = [string]$cell.Text

                if (-not [string]::IsNullOrWhiteSpace($text)) {
                    $cellPns = Get-PNsFromText -Text $text

                    foreach ($pn in $cellPns) {
                        [void]$hits.Add([PSCustomObject]@{
                            pn = $pn
                            row = $r
                            column = $c
                            cellText = $text
                        })
                    }
                }

                try {
                    [void][System.Runtime.Interopservices.Marshal]::ReleaseComObject($cell)
                } catch {}
            }
        }

        return @($hits)
    }
    catch {
        Write-Host "EROARE la citirea Excel: $FilePath" -ForegroundColor Red
        Write-Host $_.Exception.Message -ForegroundColor Red
        return @()
    }
    finally {
        try {
            if ($workbook) { $workbook.Close($false) }
        } catch {}

        try {
            if ($usedRange) { [void][System.Runtime.Interopservices.Marshal]::ReleaseComObject($usedRange) }
        } catch {}

        try {
            if ($sheet) { [void][System.Runtime.Interopservices.Marshal]::ReleaseComObject($sheet) }
        } catch {}

        try {
            if ($workbook) { [void][System.Runtime.Interopservices.Marshal]::ReleaseComObject($workbook) }
        } catch {}

        try {
            if ($excel) {
                $excel.Quit()
                [void][System.Runtime.Interopservices.Marshal]::ReleaseComObject($excel)
            }
        } catch {}

        [GC]::Collect()
        [GC]::WaitForPendingFinalizers()
    }
}

# ==============================================================================
# EXECUTIE
# ==============================================================================

Write-Host "=== GENERARE sea_index.js ===" -ForegroundColor Cyan
Write-Host "Root: $RootFolder"

$excelFiles = Get-ChildItem -Path $RootFolder -File -Recurse | Where-Object {
    $_.Extension -in @(".xls", ".xlsx", ".xlsm") -and $_.Name -notmatch '\.tmp$'
}

$filesOutput = New-Object System.Collections.Generic.List[object]
$pnMap = @{}
$processedFiles = 0

foreach ($file in $excelFiles) {
    $processedFiles++

    $relativeFilePath = Get-RelativePath -BasePath $RootFolder -FullPath $file.FullName
    $relativeFolderPath = Get-FolderPathFromFileRelativePath -RelativeFilePath $relativeFilePath
    $family = Get-FamilyFromRelativePath -RelativeFolderPath $relativeFolderPath
    $type = Get-TypeFromFilename -Filename $file.Name

    Write-Host "[$processedFiles/$($excelFiles.Count)] $relativeFilePath" -ForegroundColor DarkGray

    $fileObj = [PSCustomObject]@{
        name = $file.Name
        relativePath = $relativeFolderPath
        fullRoute = $relativeFilePath
        family = $family
        type = $type
        extension = $file.Extension
    }

    [void]$filesOutput.Add($fileObj)

    $namePns = Get-PNsFromText -Text $file.Name

    foreach ($pn in $namePns) {
        if (-not $pnMap.ContainsKey($pn)) {
            $pnMap[$pn] = [PSCustomObject]@{
                pn = $pn
                family = $family
                category = Get-Category -PN $pn
                shelf = Get-Shelf -PN $pn -Family $family
                paths = New-Object System.Collections.Generic.List[string]
                types = New-Object System.Collections.Generic.List[string]
                files = New-Object System.Collections.Generic.List[object]
            }
        }

        $entry = $pnMap[$pn]

        if (-not $entry.paths.Contains($relativeFolderPath)) {
            [void]$entry.paths.Add($relativeFolderPath)
        }

        if (-not $entry.types.Contains($type)) {
            [void]$entry.types.Add($type)
        }

        $exists = $false
        foreach ($f in $entry.files) {
            if ($f.fullRoute -eq $relativeFilePath -and $f.source -eq "filename") {
                $exists = $true
                break
            }
        }

        if (-not $exists) {
            [void]$entry.files.Add([PSCustomObject]@{
                name = $file.Name
                relativePath = $relativeFolderPath
                fullRoute = $relativeFilePath
                family = $family
                type = $type
                source = "filename"
                row = $null
                column = $null
                cellText = ""
            })
        }
    }

    $hits = Get-ExcelPNHits -FilePath $file.FullName

    foreach ($hit in $hits) {
        $pn = $hit.pn

        if (-not $pnMap.ContainsKey($pn)) {
            $pnMap[$pn] = [PSCustomObject]@{
                pn = $pn
                family = $family
                category = Get-Category -PN $pn
                shelf = Get-Shelf -PN $pn -Family $family
                paths = New-Object System.Collections.Generic.List[string]
                types = New-Object System.Collections.Generic.List[string]
                files = New-Object System.Collections.Generic.List[object]
            }
        }

        $entry = $pnMap[$pn]

        if (-not $entry.paths.Contains($relativeFolderPath)) {
            [void]$entry.paths.Add($relativeFolderPath)
        }

        if (-not $entry.types.Contains($type)) {
            [void]$entry.types.Add($type)
        }

        [void]$entry.files.Add([PSCustomObject]@{
            name = $file.Name
            relativePath = $relativeFolderPath
            fullRoute = $relativeFilePath
            family = $family
            type = $type
            source = "cell"
            row = $hit.row
            column = $hit.column
            cellText = $hit.cellText
        })
    }
}

$pnOutput = $pnMap.Values | Sort-Object pn | ForEach-Object {
    $uniqueFiles = New-Object System.Collections.Generic.List[object]
    $seen = @{}

    foreach ($f in $_.files) {
        $key = "$($f.fullRoute)|$($f.source)|$($f.row)|$($f.column)|$($f.cellText)"
        if (-not $seen.ContainsKey($key)) {
            $seen[$key] = $true
            [void]$uniqueFiles.Add($f)
        }
    }

    [PSCustomObject]@{
        pn = $_.pn
        family = $_.family
        category = $_.category
        shelf = $_.shelf
        paths = @($_.paths)
        types = @($_.types)
        files = @($uniqueFiles)
    }
}

$output = [PSCustomObject]@{
    generatedAt = (Get-Date -Format "yyyy-MM-dd HH:mm:ss")
    rootFolder = $RootFolder
    fileCount = $filesOutput.Count
    pnCount = $pnOutput.Count
    config = [PSCustomObject]@{
        rafturiFamilii = $Config.RafturiFamilii
        rafturiPN = $Config.RafturiPN
        categoriiPN = $Config.CategoriiPN
    }
    files = @($filesOutput | Sort-Object fullRoute)
    pnIndex = @($pnOutput)
}

$json = $output | ConvertTo-Json -Depth 30
$jsPath = Join-Path $RootFolder $OutputJs

[System.IO.File]::WriteAllText($jsPath, "window.SEA_INDEX = " + $json + ";", [System.Text.UTF8Encoding]::new($false))

Write-Host ""
Write-Host "=== COMPLET ===" -ForegroundColor Green
Write-Host "Fisiere Excel: $($filesOutput.Count)"
Write-Host "PN-uri unice: $($pnOutput.Count)"
Write-Host "JS generat: $jsPath"
