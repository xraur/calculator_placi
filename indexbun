<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Căutare Setup-uri SEA</title>
    <style>
        * { box-sizing: border-box; }
        body {
            margin: 0;
            min-height: 100vh;
            font-family: "Segoe UI", Tahoma, Arial, sans-serif;
            color: #172026;
            background:
                linear-gradient(135deg, rgba(20, 184, 166, 0.12), transparent 32%),
                linear-gradient(315deg, rgba(255, 107, 107, 0.12), transparent 35%),
                #f6f8fb;
        }
        .shell { width: min(1180px, calc(100% - 32px)); margin: 0 auto; padding: 28px 0 42px; }
        .topbar {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 20px;
            margin-bottom: 22px;
        }
        h1 { margin: 0 0 6px; font-size: 2rem; line-height: 1.1; color: #111827; }
        .subtitle { margin: 0; color: #5b6773; }
        .status {
            min-width: 260px;
            padding: 10px 12px;
            border: 1px solid #d9e2ea;
            border-radius: 8px;
            background: #fff;
            color: #34414d;
            font-size: 0.92rem;
        }
        .search-panel {
            border: 1px solid #d8e1e8;
            border-radius: 8px;
            background: #fff;
            padding: 18px;
            box-shadow: 0 14px 36px rgba(26, 37, 51, 0.08);
        }
        .search-row { display: grid; grid-template-columns: 1fr auto auto; gap: 12px; align-items: center; }
        #searchInput {
            width: 100%;
            height: 54px;
            padding: 0 16px;
            border: 2px solid #14b8a6;
            border-radius: 8px;
            background: #fbfdff;
            color: #101820;
            font-size: 1rem;
            outline: none;
        }
        #searchInput:focus { box-shadow: 0 0 0 4px rgba(20, 184, 166, 0.14); }
        .search-btn,
        .clear-btn {
            height: 54px;
            border: 0;
            border-radius: 8px;
            padding: 0 18px;
            color: #fff;
            font-weight: 700;
            cursor: pointer;
        }
        .search-btn { background: #16a34a; }
        .clear-btn { background: #ff6b6b; }
        .shelves {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
            gap: 10px;
            margin: 18px 0;
        }
        .shelf {
            border: 1px solid #d8e1e8;
            border-left: 4px solid #14b8a6;
            border-radius: 8px;
            padding: 10px;
            background: #fff;
        }
        .shelf strong { display: block; font-size: 1rem; color: #0f766e; }
        .shelf span { display: block; margin-top: 3px; color: #6a7682; font-size: 0.82rem; }
        #results { margin-top: 18px; }
        .empty {
            border: 1px dashed #b9c6d2;
            border-radius: 8px;
            padding: 26px;
            background: rgba(255,255,255,.72);
            color: #53616e;
            text-align: center;
        }
        .result-card {
            display: grid;
            grid-template-columns: minmax(0,1fr) auto;
            gap: 16px;
            margin-bottom: 12px;
            border: 1px solid #d8e1e8;
            border-left: 6px solid #14b8a6;
            border-radius: 8px;
            background: #fff;
            padding: 16px;
            box-shadow: 0 10px 28px rgba(26,37,51,.07);
        }
        .pn { margin: 0; color: #111827; font-size: 1.28rem; overflow-wrap: anywhere; }
        .meta { display: flex; flex-wrap: wrap; gap: 8px; margin: 10px 0 12px; }
        .pill {
            display: inline-flex;
            align-items: center;
            min-height: 26px;
            padding: 4px 9px;
            border-radius: 8px;
            background: #edf7f6;
            color: #0f766e;
            font-size: .84rem;
            font-weight: 700;
        }
        .pill.type { background: #fef3c7; color: #9a5b00; }
        .pill.category { background: #eef2ff; color: #3655a4; }
        .route {
            margin-top: 10px;
            color: #46515c;
            line-height: 1.45;
            overflow-wrap: anywhere;
        }
        .files { margin-top: 12px; display: grid; gap: 7px; }
        .file-row {
            padding: 10px;
            border-radius: 8px;
            background: #f5f7fa;
            color: #2d3843;
            overflow-wrap: anywhere;
        }
        .file-line { margin-top: 4px; color: #61707d; font-size: .92rem; }
        .side { min-width: 150px; text-align: right; color: #44515d; }
        .shelf-badge {
            display: inline-block;
            min-width: 80px;
            padding: 8px 10px;
            border-radius: 8px;
            background: #111827;
            color: #fff;
            font-weight: 800;
            text-align: center;
        }
        .muted { color: #71808f; font-size: .9rem; }
        @media (max-width: 720px) {
            .topbar { display: block; }
            .status { margin-top: 14px; min-width: 0; }
            .search-row { grid-template-columns: 1fr; }
            .search-btn, .clear-btn { width: 100%; }
            .result-card { grid-template-columns: 1fr; }
            .side { text-align: left; }
        }
    </style>
</head>
<body>
    <main class="shell">
        <section class="topbar">
            <div>
                <h1>Căutare setup-uri SEA</h1>
                <p class="subtitle">Dublu click pe index.html. Caută PN, familie, tip, fișier sau traseu.</p>
            </div>
            <div class="status" id="stats">Încarc datele...</div>
        </section>

        <section class="search-panel">
            <div class="search-row">
                <input id="searchInput" type="text" placeholder="Ex: SEA4-GEX47545_06, Nikko, handload, assy" oninput="search()" onkeydown="handleSearchKey(event)">
                <button class="search-btn" onclick="search()">Caută</button>
                <button class="clear-btn" onclick="clearSearch()">Curăță</button>
            </div>
        </section>

        <section class="shelves" id="shelvesDisplay"></section>
        <section id="results"><div class="empty">Scrie ce cauți.</div></section>
    </main>

    <script src="sea_index.js"></script>
    <script>
        let rawData = null;
        let pnIndex = [];
        let filesIndex = [];

        function escapeHtml(text) {
            return String(text || "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");
        }

        function normalizeSearch(text) {
            return String(text || "")
                .toLowerCase()
                .normalize("NFD")
                .replace(/[\u0300-\u036f]/g, "")
                .replace(/[^a-z0-9]+/g, " ")
                .trim();
        }

        function compact(text) {
            return normalizeSearch(text).replace(/\s+/g, "");
        }

        function searchTerms(text) {
            return normalizeSearch(text).split(/\s+/).filter(Boolean);
        }

        function getSearchFields(item) {
            return [
                item.pn,
                item.family,
                item.category,
                item.shelf,
                ...(item.paths || []),
                ...(item.types || []),
                ...((item.files || []).flatMap(file => [
                    file.name,
                    file.relativePath,
                    file.fullRoute,
                    file.type,
                    file.family,
                    file.source,
                    file.row,
                    file.column,
                    file.cellText
                ]))
            ].filter(Boolean);
        }

        function updateStats() {
            const stats = document.getElementById("stats");
            const pnCount = pnIndex.length;
            const fileCount = filesIndex.length;
            const generatedAt = rawData?.generatedAt || "-";
            stats.textContent = `${pnCount} PN-uri, ${fileCount} fișiere | generat: ${generatedAt}`;
        }

        function renderShelves() {
            const box = document.getElementById("shelvesDisplay");
            const config = rawData?.config || {};
            const rafturiFamilii = config.rafturiFamilii || {};
            const rafturiPN = config.rafturiPN || {};

            const familyEntries = Object.entries(rafturiFamilii);
            const pnEntries = Object.entries(rafturiPN);

            if (!familyEntries.length && !pnEntries.length) {
                box.innerHTML = "";
                return;
            }

            const familyHtml = familyEntries.map(([key, shelves]) => `
                <div class="shelf">
                    <strong>${escapeHtml(key)}</strong>
                    <span>${escapeHtml([].concat(shelves).join(", "))}</span>
                </div>
            `).join("");

            const pnHtml = pnEntries.map(([key, shelves]) => `
                <div class="shelf">
                    <strong>${escapeHtml(key)}</strong>
                    <span>${escapeHtml([].concat(shelves).join(", "))}</span>
                </div>
            `).join("");

            box.innerHTML = familyHtml + pnHtml;
        }

        function scoreItem(query, item) {
            const terms = searchTerms(query);
            if (!terms.length) return 0;

            const fields = getSearchFields(item);
            const text = normalizeSearch(fields.join(" "));
            const compactText = compact(fields.join(" "));
            const queryNorm = normalizeSearch(query);
            const queryCompact = compact(query);

            let score = 0;

            if (compact(item.pn) === queryCompact) score += 1000;
            if (text.includes(queryNorm)) score += 300;
            if (queryCompact.length >= 3 && compactText.includes(queryCompact)) score += 260;

            for (const term of terms) {
                let found = false;

                for (const field of fields) {
                    const nf = normalizeSearch(field);
                    const cf = compact(field);

                    if (nf === term || cf === compact(term)) {
                        score += 140;
                        found = true;
                        break;
                    }

                    if (nf.includes(term) || cf.includes(compact(term))) {
                        score += 100;
                        found = true;
                        break;
                    }
                }

                if (!found) return 0;
            }

            return score;
        }

        function renderResults(items) {
            const results = document.getElementById("results");

            if (!items.length) {
                results.innerHTML = '<div class="empty">Nu am găsit nimic.</div>';
                return;
            }

            results.innerHTML = items.map(item => {
                const types = [...new Set(item.types || [])];
                const files = item.files || [];
                const paths = item.paths || [];

                return `
                    <article class="result-card">
                        <div>
                            <h2 class="pn">${escapeHtml(item.pn)}</h2>

                            <div class="meta">
                                <span class="pill">${escapeHtml(item.family || "Necunoscut")}</span>
                                <span class="pill category">${escapeHtml(item.category || "Necategorisit")}</span>
                                ${types.map(type => `<span class="pill type">${escapeHtml(type)}</span>`).join("")}
                            </div>

                            <div class="route">
                                <strong>Foldere găsite:</strong>
                                ${paths.length ? escapeHtml(paths.join(" | ")) : "—"}
                            </div>

                            <div class="files">
                                ${files.length ? files.map(file => `
                                    <div class="file-row">
                                        <div><strong>${escapeHtml(file.name)}</strong></div>
                                        <div class="file-line">Tip: ${escapeHtml(file.type || "Setup")}</div>
                                        <div class="file-line">Familie: ${escapeHtml(file.family || "Necunoscut")}</div>
                                        <div class="file-line">Folder: ${escapeHtml(file.relativePath || "—")}</div>
                                        <div class="file-line">Traseu complet: ${escapeHtml(file.fullRoute || file.name)}</div>
                                        <div class="file-line">Sursă: ${file.source === "cell" ? "celulă Excel" : "nume fișier"}</div>
                                        ${file.source === "cell" ? `<div class="file-line">Celulă: rând ${escapeHtml(file.row)} / coloană ${escapeHtml(file.column)}</div>` : ""}
                                        ${file.source === "cell" && file.cellText ? `<div class="file-line">Text celulă: ${escapeHtml(file.cellText)}</div>` : ""}
                                    </div>
                                `).join("") : '<div class="file-row">Niciun fișier.</div>'}
                            </div>
                        </div>

                        <div class="side">
                            <div class="shelf-badge">
                                ${item.shelf && item.shelf !== "?" ? `Raft ${escapeHtml(item.shelf)}` : "Fără raft"}
                            </div>
                            <div class="muted">${item.shelf && item.shelf !== "?" ? "din configurare" : ""}</div>
                        </div>
                    </article>
                `;
            }).join("");
        }

        function search() {
            const query = document.getElementById("searchInput").value.trim();
            const results = document.getElementById("results");

            if (!query) {
                results.innerHTML = '<div class="empty">Scrie ce cauți.</div>';
                return;
            }

            const matches = pnIndex
                .map(item => ({ item, score: scoreItem(query, item) }))
                .filter(entry => entry.score > 0)
                .sort((a, b) => b.score - a.score || a.item.pn.localeCompare(b.item.pn))
                .map(entry => entry.item);

            renderResults(matches);
        }

        function clearSearch() {
            document.getElementById("searchInput").value = "";
            document.getElementById("results").innerHTML = '<div class="empty">Scrie ce cauți.</div>';
            document.getElementById("searchInput").focus();
        }

        function handleSearchKey(event) {
            if (event.key === "Enter") {
                event.preventDefault();
                search();
            }
        }

        function init() {
            if (!window.SEA_INDEX) {
                document.getElementById("stats").textContent = "Lipsește sea_index.js";
                document.getElementById("results").innerHTML =
                    '<div class="empty">Pune <strong>sea_index.js</strong> lângă <strong>index.html</strong>.</div>';
                return;
            }

            rawData = window.SEA_INDEX;
            pnIndex = Array.isArray(rawData.pnIndex) ? rawData.pnIndex : [];
            filesIndex = Array.isArray(rawData.files) ? rawData.files : [];

            updateStats();
            renderShelves();

            document.getElementById("results").innerHTML =
                '<div class="empty">Date încărcate. Scrie ce cauți.</div>';
        }

        window.addEventListener("load", init);
    </script>
</body>
</html>
