<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Căutare Setup-uri SEA</title>
    <style>
        * { box-sizing: border-box; }
        body {
            margin: 0;
            min-height: 100vh;
            font-family: "Segoe UI", Tahoma, Arial, sans-serif;
            color: #172026;
            background:
                linear-gradient(135deg, rgba(20, 184, 166, 0.12), transparent 32%),
                linear-gradient(315deg, rgba(255, 107, 107, 0.12), transparent 35%),
                #f6f8fb;
        }
        .shell { width: min(1180px, calc(100% - 32px)); margin: 0 auto; padding: 28px 0 42px; }
        .topbar {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 20px;
            margin-bottom: 22px;
        }
        h1 { margin: 0 0 6px; font-size: 2rem; line-height: 1.1; color: #111827; }
        .subtitle { margin: 0; color: #5b6773; }
        .status {
            min-width: 230px;
            padding: 10px 12px;
            border: 1px solid #d9e2ea;
            border-radius: 8px;
            background: #fff;
            color: #34414d;
            font-size: 0.92rem;
        }
        .search-panel {
            border: 1px solid #d8e1e8;
            border-radius: 8px;
            background: #fff;
            padding: 18px;
            box-shadow: 0 14px 36px rgba(26, 37, 51, 0.08);
        }
        .search-row { display: grid; grid-template-columns: 1fr auto auto; gap: 12px; align-items: center; }
        #searchInput {
            width: 100%;
            height: 54px;
            padding: 0 16px;
            border: 2px solid #14b8a6;
            border-radius: 8px;
            background: #fbfdff;
            color: #101820;
            font-size: 1rem;
            outline: none;
        }
        #searchInput:focus { box-shadow: 0 0 0 4px rgba(20, 184, 166, 0.14); }
        .search-btn,
        .clear-btn {
            height: 54px;
            border: 0;
            border-radius: 8px;
            padding: 0 18px;
            color: #fff;
            font-weight: 700;
            cursor: pointer;
        }
        .search-btn { background: #16a34a; }
        .clear-btn { background: #ff6b6b; }
        .hint { margin-top: 10px; color: #687684; font-size: 0.9rem; }
        .shelves {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
            gap: 10px;
            margin: 18px 0;
        }
        .shelf {
            border: 1px solid #d8e1e8;
            border-left: 4px solid #14b8a6;
            border-radius: 8px;
            padding: 10px;
            background: #fff;
        }
        .shelf strong { display: block; font-size: 1rem; color: #0f766e; }
        .shelf span { display: block; margin-top: 3px; color: #6a7682; font-size: 0.82rem; }
        #results { margin-top: 18px; }
        .empty {
            border: 1px dashed #b9c6d2;
            border-radius: 8px;
            padding: 26px;
            background: rgba(255, 255, 255, 0.72);
            color: #53616e;
            text-align: center;
        }
        .result-card {
            position: relative;
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            gap: 16px;
            margin-bottom: 12px;
            border: 1px solid #d8e1e8;
            border-left: 6px solid #14b8a6;
            border-radius: 8px;
            background: #fff;
            padding: 16px;
            box-shadow: 0 10px 28px rgba(26, 37, 51, 0.07);
        }
        .result-card.cutie { border-left-color: #22c55e; }
        .result-card.placa { border-left-color: #f59e0b; }
        .result-card.componenta { border-left-color: #3b82f6; }
        .result-card.burete { border-left-color: #ec4899; }
        .pn { margin: 0; color: #111827; font-size: 1.28rem; overflow-wrap: anywhere; }
        .meta {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin: 10px 0 12px;
        }
        .pill {
            display: inline-flex;
            align-items: center;
            min-height: 26px;
            padding: 4px 9px;
            border-radius: 8px;
            background: #edf7f6;
            color: #0f766e;
            font-size: 0.84rem;
            font-weight: 700;
        }
        .pill.type { background: #fef3c7; color: #9a5b00; }
        .pill.path-source { background: #eef2ff; color: #3655a4; }
        .route {
            margin-top: 10px;
            color: #46515c;
            line-height: 1.45;
            overflow-wrap: anywhere;
        }
        .files {
            margin-top: 12px;
            display: grid;
            gap: 7px;
        }
        .file-row {
            padding: 8px 10px;
            border-radius: 8px;
            background: #f5f7fa;
            color: #2d3843;
            overflow-wrap: anywhere;
        }
        .side {
            min-width: 120px;
            text-align: right;
            color: #44515d;
        }
        .shelf-badge {
            display: inline-block;
            min-width: 54px;
            padding: 8px 10px;
            border-radius: 8px;
            background: #111827;
            color: #fff;
            font-weight: 800;
            text-align: center;
        }
        .muted { color: #71808f; font-size: 0.9rem; }
        .alts { margin-top: 12px; display: flex; gap: 8px; flex-wrap: wrap; justify-content: center; }
        .alt {
            border: 1px solid #14b8a6;
            border-radius: 8px;
            padding: 7px 10px;
            background: #fff;
            color: #0f766e;
            cursor: pointer;
            font-weight: 700;
        }
        @media (max-width: 720px) {
            .topbar { display: block; }
            .status { margin-top: 14px; min-width: 0; }
            .search-row { grid-template-columns: 1fr; }
            .search-btn, .clear-btn { width: 100%; }
            .result-card { grid-template-columns: 1fr; }
            .side { text-align: left; }
        }
    </style>
</head>
<body>
    <main class="shell">
        <section class="topbar">
            <div>
                <h1>Căutare setup-uri SEA</h1>
                <p class="subtitle">Caută PN-ul și vezi familia, categoria, fișierele și traseul exact.</p>
            </div>
            <div class="status" id="stats">Încarc datele...</div>
        </section>

        <section class="search-panel">
            <div class="search-row">
                <input id="searchInput" type="text" placeholder="Ex: Bit Box handload, Nikko assy, SEA4-GEX47545_06" oninput="search()" onkeydown="handleSearchKey(event)">
                <button class="search-btn" onclick="search()">Caută</button>
                <button class="clear-btn" onclick="clearSearch()">Curăță</button>
            </div>
        </section>

        <section class="shelves" id="shelvesDisplay"></section>
        <section id="results"><div class="empty">Scrie ce cauți.</div></section>
    </main>

    <script src="structura_data.js"></script>
    <script src="structura setup sea.js"></script>
    <script src="Structura_Setup_SEA.js"></script>
    <script>
        // ==========================================================================
        // CONFIGURAREA TA - MODIFICI DOAR AICI
        // ==========================================================================
        const CONFIGURARE = {
            // 1) Rafturi / locații pentru familii.
            // Familia = primul folder din structura. Exemple: "Bit Box", "Nikko", "P5".
            // Scrii locațiile exact cum sunt ele: "MODULU 1", "MODULU 5", "A 2", "B 5".
            rafturiFamilii: {
                // "Bit Box": ["MODULU 1", "A 2", "A 6"],
                // "Nikko": ["MODULU 5", "B 5"],
                // "P5": ["C 1"],
            },

            // 2) Excepții pentru PN-uri sau prefixe de PN.
            // Asta bate peste raftul familiei. Folosesti doar daca trebuie.
            rafturiPN: {
                // "SEAH-Z701440-02": ["MODULU 5"],
                // "SEA4-WHOLM": ["A 4"], // toate PN-urile care incep cu SEA4-WHOLM
            },

            // 3) Categorii simple.
            // Exemplu: toate PN-urile care incep cu SEA4-WHOLM sunt Cutii.
            categoriiPN: [
                // { categorie: "Cutii", incepeCu: ["SEA4-WHOLM"] },
                // { categorie: "Bureti", incepeCu: ["SEA4-SPG"] },
                // { categorie: "Placi", incepeCu: ["SEA4-NNZ8", "F-09-0118_C1"] },
                // { categorie: "Componente", incepeCu: ["SEA4-HRB"] },
            ]
        };

        let allData = [];
        let sourceFile = "";

        function normalize(text) {
            return String(text || "").trim();
        }

        function escapeHtml(text) {
            return String(text || "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");
        }

        function getTypeFromFilename(filename) {
            const lower = filename.toLowerCase();
            if (lower.includes("assy") || lower.includes("asamblare") || lower.includes("assembly")) return "Assy";
            if (lower.includes("prep") || lower.includes("preparare")) return "Prep";
            if (lower.includes("handload") || lower.includes("hand load") || /\bhl\b/.test(lower)) return "Handload";
            if (lower.includes("hand solder") || lower.includes("soldering") || /\bhs\b/.test(lower)) return "Hand Soldering";
            if (lower.includes("pressfit") || lower.includes("press fit") || /\bpf\b/.test(lower)) return "Pressfit";
            if (lower.includes("pack") || lower.includes("product pack")) return "Pack";
            if (lower.includes("label")) return "Label";
            if (lower.includes("light guide")) return "Light Guide";
            return "Setup";
        }

        function extractPNs(text) {
            const value = String(text || "").toUpperCase();
            const patterns = [
                /SEA[0-9H]*-[A-Z0-9]+(?:[-_][A-Z0-9]+)*/g,
                /F-09-0118(?:[-_][A-Z0-9]+)*(?:\s+[A-Z0-9]+){0,3}/g
            ];
            const found = new Set();
            patterns.forEach((pattern) => {
                const matches = value.match(pattern) || [];
                matches.forEach((raw) => {
                    const pn = raw.replace(/\.(XLSX?|XLSM)$/i, "").replace(/[-_\s]+$/g, "").trim();
                    if (pn.length >= 8) found.add(pn);
                });
            });
            return [...found];
        }

        function firstFolder(path) {
            const cleaned = normalize(path).replaceAll("\\", "/");
            return cleaned.split("/").filter(Boolean)[0] || "Necunoscut";
        }

        function getShelf(pn, family) {
            const upper = String(pn || "").toUpperCase();
            const pnKey = Object.keys(CONFIGURARE.rafturiPN)
                .sort((a, b) => b.length - a.length)
                .find((prefix) => upper.startsWith(prefix));
            if (pnKey) return [].concat(CONFIGURARE.rafturiPN[pnKey]).join(", ");

            const familyKey = Object.keys(CONFIGURARE.rafturiFamilii)
                .find((name) => name.toLowerCase() === String(family || "").toLowerCase());
            if (familyKey) return [].concat(CONFIGURARE.rafturiFamilii[familyKey]).join(", ");

            return "?";
        }

        function matchesAnyRule(pn, rules) {
            const upper = String(pn || "").toUpperCase();
            return rules.some((rule) => upper.startsWith(String(rule).toUpperCase()));
        }

        function classify(pn) {
            const found = CONFIGURARE.categoriiPN.find((rule) => matchesAnyRule(pn, rule.incepeCu || []));
            if (found) return { key: slug(found.categorie), label: found.categorie };
            return { key: "necategorizat", label: "Necategorisit" };
        }

        function categoryFromText(text, pn) {
            const label = normalize(text);
            if (!label || label === "Necategorisit") return classify(pn);
            return { key: slug(label), label };
        }

        function slug(text) {
            return String(text || "necategorizat")
                .toLowerCase()
                .normalize("NFD")
                .replace(/[\u0300-\u036f]/g, "")
                .replace(/[^a-z0-9]+/g, "-")
                .replace(/^-|-$/g, "") || "necategorizat";
        }

        function makeItem(pn, file, path, type) {
            const route = normalize(path);
            const family = firstFolder(route);
            return {
                pn: normalize(pn).toUpperCase(),
                family,
                category: classify(pn),
                shelf: getShelf(pn, family),
                paths: route ? [route] : [],
                files: file ? [{ name: normalize(file), path: route, type: type || getTypeFromFilename(file) }] : [],
                types: type ? [type] : []
            };
        }

        function addItem(map, item) {
            if (!item || !item.pn) return;
            if (!map.has(item.pn)) {
                map.set(item.pn, item);
                return;
            }
            const existing = map.get(item.pn);
            item.files.forEach((file) => {
                if (!existing.files.some((f) => f.name === file.name && f.path === file.path)) existing.files.push(file);
            });
            item.paths.forEach((path) => {
                if (path && !existing.paths.includes(path)) existing.paths.push(path);
            });
            item.types.forEach((type) => {
                if (type && !existing.types.includes(type)) existing.types.push(type);
            });
            if (existing.shelf === "?") existing.shelf = item.shelf;
        }

        function parseStructuredData(text) {
            const map = new Map();
            const lines = text.split(/\r?\n/);
            let current = null;

            function flush() {
                if (current && current.pn) addItem(map, current);
            }

            lines.forEach((raw) => {
                const line = raw.trim();
                if (!line) return;

                if (line.startsWith("--- PN:")) {
                    flush();
                    const pn = line.replace("--- PN:", "").replace("---", "").trim();
                    current = makeItem(pn, "", "", "");
                    return;
                }
                if (!current) return;

                if (line.startsWith("Tip:")) {
                    const type = line.replace("Tip:", "").trim();
                    if (type && !current.types.includes(type)) current.types.push(type);
                    return;
                }
                if (line.startsWith("Fisier:")) {
                    const name = line.replace("Fisier:", "").trim();
                    if (name && !current.files.some((f) => f.name === name)) {
                        current.files.push({ name, path: current.paths[0] || "", type: getTypeFromFilename(name) });
                    }
                    return;
                }
                if (line.startsWith("Familie:")) {
                    const rawFamily = line.replace("Familie:", "").trim();
                    current.family = rawFamily.replace(/^Familie:\s*/i, "").replace(/^Cutie:\s*/i, "") || current.family;
                    return;
                }
                if (line.startsWith("Categorie:")) {
                    current.category = categoryFromText(line.replace("Categorie:", "").trim(), current.pn);
                    return;
                }
                if (line.startsWith("Raft:")) {
                    current.shelf = line.replace("Raft:", "").trim() || current.shelf;
                    return;
                }
                if (line.startsWith("Loca:")) {
                    const path = line.replace("Loca:", "").trim();
                    if (path && !current.paths.includes(path)) current.paths.push(path);
                    current.family = firstFolder(path);
                    if (current.shelf === "?") current.shelf = getShelf(current.pn, current.family);
                    current.files.forEach((file) => { if (!file.path) file.path = path; });
                }
            });
            flush();
            return [...map.values()];
        }

        function parseTreeData(text) {
            const map = new Map();
            const stack = [];
            const lines = text.split(/\r?\n/);

            lines.forEach((raw) => {
                const dirMatch = raw.match(/^([|\s]*)(\+---|\\---)(.+)$/);
                if (dirMatch) {
                    const depth = Math.floor(dirMatch[1].length / 4);
                    stack[depth] = dirMatch[3].trim();
                    stack.length = depth + 1;
                    return;
                }

                if (!/\.(xls|xlsx|xlsm)\b/i.test(raw) || /(\+---|\\---)/.test(raw)) return;

                const fileMatch = raw.match(/^([|\s]*)(.+\.(?:xls|xlsx|xlsm).*)$/i);
                if (!fileMatch) return;

                const depth = Math.max(0, Math.floor(fileMatch[1].length / 4) - 1);
                const path = stack.slice(0, depth + 1).join("/");
                const file = fileMatch[2].trim();
                const pns = extractPNs(file);

                pns.forEach((pn) => addItem(map, makeItem(pn, file, path, getTypeFromFilename(file))));
            });

            return [...map.values()];
        }

        function parseData(text) {
            const structured = text.includes("--- PN:") ? parseStructuredData(text) : [];
            allData = structured.length ? structured : parseTreeData(text);
            allData.sort((a, b) => a.pn.localeCompare(b.pn));
            updateStats();
            renderShelves();
            document.getElementById("results").innerHTML = allData.length
                ? '<div class="empty">Date încărcate. Scrie ce cauți.</div>'
                : '<div class="empty">Nu am găsit PN-uri în fișierul de structură.</div>';
        }

        async function loadFromFile() {
            if (window.STRUCTURA_SEA_TEXT) {
                sourceFile = window.STRUCTURA_SEA_SOURCE || "structura_data.js";
                parseData(window.STRUCTURA_SEA_TEXT);
                return;
            }

            const candidates = ["Structura_Setup_SEA.txt", "structura setup sea.txt", "structura_SEA.txt", "structura.txt"];
            for (const file of candidates) {
                try {
                    const response = await fetch(file, { cache: "no-store" });
                    if (!response.ok) continue;
                    sourceFile = file;
                    parseData(await readResponseText(response));
                    return;
                } catch (error) {
                    // Încerc următorul fișier.
                }
            }
            allData = [];
            sourceFile = "niciun fișier";
            updateStats();
            document.getElementById("results").innerHTML =
                '<div class="empty">Nu găsesc Structura_Setup_SEA.txt, structura_SEA.txt sau structura.txt lângă index.html.</div>';
        }

        async function readResponseText(response) {
            const buffer = await response.arrayBuffer();
            const bytes = new Uint8Array(buffer);
            if (bytes[0] === 0xff && bytes[1] === 0xfe) {
                return new TextDecoder("utf-16le").decode(bytes);
            }
            if (bytes[0] === 0xfe && bytes[1] === 0xff) {
                return new TextDecoder("utf-16be").decode(bytes);
            }
            return new TextDecoder("utf-8").decode(bytes);
        }

        function renderShelves() {
            const shelfDiv = document.getElementById("shelvesDisplay");
            const familyEntries = Object.entries(CONFIGURARE.rafturiFamilii);
            const pnEntries = Object.entries(CONFIGURARE.rafturiPN);
            if (!familyEntries.length && !pnEntries.length) {
                shelfDiv.innerHTML = "";
                return;
            }
            const familyHtml = familyEntries.map(([family, shelves]) => `
                <div class="shelf">
                    <strong>${escapeHtml(family)}</strong>
                    <span>${escapeHtml([].concat(shelves).join(", "))}</span>
                </div>
            `).join("");
            const pnHtml = pnEntries.map(([prefix, shelves]) => `
                <div class="shelf">
                    <strong>${escapeHtml(prefix)}</strong>
                    <span>${escapeHtml([].concat(shelves).join(", "))}</span>
                </div>
            `).join("");
            shelfDiv.innerHTML = familyHtml + pnHtml;
        }

        function updateStats() {
            const files = new Set();
            allData.forEach((item) => item.files.forEach((file) => files.add(file.name + "|" + file.path)));
            document.getElementById("stats").textContent =
                `${allData.length} PN-uri, ${files.size} fișiere | sursă: ${sourceFile || "în curs"}`;
        }

        function normalizeSearch(text) {
            return String(text || "")
                .toLowerCase()
                .normalize("NFD")
                .replace(/[\u0300-\u036f]/g, "")
                .replace(/[^a-z0-9]+/g, " ")
                .trim();
        }

        function compactSearch(text) {
            return normalizeSearch(text).replace(/\s+/g, "");
        }

        function searchTerms(query) {
            return normalizeSearch(query).split(/\s+/).filter(Boolean);
        }

        function itemSearchFields(item) {
            return [
                item.pn,
                item.family,
                item.category.label,
                item.shelf,
                ...item.types,
                ...item.paths,
                ...item.files.flatMap((file) => [file.name, file.path, file.type])
            ].filter(Boolean);
        }

        function itemSearchText(item) {
            return itemSearchFields(item).join(" ");
        }

        function levenshtein(a, b) {
            if (a === b) return 0;
            if (!a.length) return b.length;
            if (!b.length) return a.length;

            const prev = Array.from({ length: b.length + 1 }, (_, i) => i);
            const curr = new Array(b.length + 1);

            for (let i = 1; i <= a.length; i++) {
                curr[0] = i;
                for (let j = 1; j <= b.length; j++) {
                    const cost = a[i - 1] === b[j - 1] ? 0 : 1;
                    curr[j] = Math.min(
                        curr[j - 1] + 1,
                        prev[j] + 1,
                        prev[j - 1] + cost
                    );
                }
                for (let j = 0; j <= b.length; j++) prev[j] = curr[j];
            }

            return prev[b.length];
        }

        function maxTypoDistance(term) {
            if (term.length <= 2) return 0;
            if (term.length <= 6) return 1;
            return 2;
        }

        function tokenScore(term, fields) {
            const compactTerm = compactSearch(term);
            let best = 0;

            for (const field of fields) {
                const normalized = normalizeSearch(field);
                const compact = compactSearch(field);
                if (!normalized && !compact) continue;

                if (normalized === term || compact === compactTerm) best = Math.max(best, 180);
                else if (normalized.includes(term) || compact.includes(compactTerm)) best = Math.max(best, 130);

                const words = normalized.split(/\s+/).filter(Boolean);
                for (const word of words) {
                    if (word === term) best = Math.max(best, 170);
                    else if (word.startsWith(term) || term.startsWith(word)) best = Math.max(best, 115);
                    else if (Math.abs(word.length - term.length) <= maxTypoDistance(term)) {
                        const distance = levenshtein(term, word);
                        if (distance <= maxTypoDistance(term)) best = Math.max(best, 95 - distance * 15);
                    }
                }

                if (Math.abs(compact.length - compactTerm.length) <= maxTypoDistance(term)) {
                    const compactDistance = levenshtein(compactTerm, compact);
                    if (compactDistance <= maxTypoDistance(term)) best = Math.max(best, 90 - compactDistance * 15);
                }
            }

            return best;
        }

        function scoreMatch(query, item) {
            const terms = searchTerms(query);
            if (!terms.length) return 0;

            const fields = itemSearchFields(item);
            const normalizedQuery = normalizeSearch(query);
            const compactQuery = compactSearch(query);
            const normalizedText = normalizeSearch(itemSearchText(item));
            const compactText = compactSearch(itemSearchText(item));

            let score = 0;
            if (normalizedText.includes(normalizedQuery)) score += 500;
            if (compactQuery.length > 2 && compactText.includes(compactQuery)) score += 450;
            if (compactSearch(item.pn) === compactQuery) score += 1000;

            for (const term of terms) {
                const partScore = tokenScore(term, fields);
                if (!partScore) return 0;
                score += partScore;
            }

            return score;
        }

        function search() {
            const query = document.getElementById("searchInput").value.trim();
            const resultsDiv = document.getElementById("results");
            if (!query) {
                resultsDiv.innerHTML = '<div class="empty">Scrie ce cauți.</div>';
                return;
            }

            const matches = allData
                .map((item) => ({ item, score: scoreMatch(query, item) }))
                .filter((entry) => entry.score > 0)
                .sort((a, b) => b.score - a.score || a.item.pn.localeCompare(b.item.pn))
                .map((entry) => entry.item);

            if (!matches.length) {
                const alts = generateAlternatives(query, true);
                const altHtml = alts.length
                    ? `<div class="alts">${alts.map((alt) => `<button class="alt" onclick="searchAlt('${escapeHtml(alt)}')">${escapeHtml(alt)}</button>`).join("")}</div>`
                    : "";
                resultsDiv.innerHTML = `
                    <div class="empty">
                        N-am găsit nimic.${alts.length ? " Încearcă:" : ""}
                        ${altHtml}
                    </div>
                `;
                return;
            }

            const suggestions = generateAlternatives(query, false);
            const suggestionHtml = suggestions.length ? `
                <div class="empty" style="margin-bottom:12px;">
                    Poate cauți:
                    <div class="alts">${suggestions.map((alt) => `<button class="alt" onclick="searchAlt('${escapeHtml(alt)}')">${escapeHtml(alt)}</button>`).join("")}</div>
                </div>
            ` : "";

            resultsDiv.innerHTML = suggestionHtml + renderResults(matches);
        }

        function generateAlternatives(query, includeFallback) {
            const terms = searchTerms(query);
            if (!terms.length || !allData.length) return [];

            const vocabulary = buildSearchVocabulary();
            const replacements = [];
            let changed = false;

            for (const term of terms) {
                const best = closestVocabularyWord(term, vocabulary);
                if (best && best.normalized !== term) {
                    replacements.push(best.label);
                    changed = true;
                } else {
                    replacements.push(term);
                }
            }

            const suggestions = [];
            if (changed) suggestions.push(replacements.join(" "));

            const compactQuery = compactSearch(query);
            const compactHit = vocabulary.find((entry) => entry.compact === compactQuery);
            if (compactHit && compactHit.label.toLowerCase() !== query.toLowerCase()) {
                suggestions.push(compactHit.label);
            }

            return [...new Set(suggestions
                .map((value) => String(value || "").trim())
                .filter((value) => value.length >= 3 && normalizeSearch(value) !== normalizeSearch(query))
                .filter((value) => suggestionHasResults(value))
            )].slice(0, 5);
        }

        function suggestionHasResults(value) {
            return allData.some((item) => scoreMatch(value, item) > 0);
        }

        function buildSearchVocabulary() {
            const map = new Map();

            function add(label) {
                const clean = normalizeSearch(label);
                if (!clean) return;

                const compact = compactSearch(label);
                if (!map.has(clean)) map.set(clean, { label: String(label).trim(), normalized: clean, compact });
                if (compact.length >= 3 && compact !== clean && !map.has(compact)) {
                    map.set(compact, { label: String(label).trim(), normalized: compact, compact });
                }

                clean.split(/\s+/).forEach((word) => {
                    if (word.length >= 3 && !map.has(word)) {
                        map.set(word, { label: word, normalized: word, compact: word });
                    }
                });
            }

            allData.forEach((item) => itemSearchFields(item).forEach(add));
            return [...map.values()];
        }

        function closestVocabularyWord(term, vocabulary) {
            if (term.length < 3) return null;

            let best = null;
            for (const entry of vocabulary) {
                if (Math.abs(entry.normalized.length - term.length) > maxTypoDistance(term)) continue;
                const distance = levenshtein(term, entry.normalized);
                if (distance <= maxTypoDistance(term) && (!best || distance < best.distance)) {
                    best = { ...entry, distance };
                }
            }

            return best;
        }

        function searchAlt(value) {
            document.getElementById("searchInput").value = value;
            search();
        }

        function handleSearchKey(event) {
            if (event.key === "Enter") {
                event.preventDefault();
                search();
            }
        }

        function clearSearch() {
            document.getElementById("searchInput").value = "";
            search();
            document.getElementById("searchInput").focus();
        }

        function renderResults(matches) {
            return matches.map((item) => {
                const types = [...new Set([
                    ...item.types,
                    ...item.files.map((file) => file.type)
                ].filter(Boolean))];
                const fileRows = item.files.length
                    ? item.files.map((file) => `
                        <div class="file-row">
                            <strong>${escapeHtml(file.type || "Setup")}:</strong>
                            ${escapeHtml(file.name)}
                            ${file.path ? `<div class="muted">${escapeHtml(file.path)}</div>` : ""}
                        </div>
                    `).join("")
                    : '<div class="file-row">Fără fișier listat în structură.</div>';

                return `
                    <article class="result-card ${escapeHtml(item.category.key)}">
                        <div>
                            <h2 class="pn">${escapeHtml(item.pn)}</h2>
                            <div class="meta">
                                <span class="pill">${escapeHtml(item.family)}</span>
                                <span class="pill path-source">${escapeHtml(item.category.label)}</span>
                                ${types.map((type) => `<span class="pill type">${escapeHtml(type)}</span>`).join("")}
                            </div>
                            <div class="route"><strong>Traseu:</strong> ${escapeHtml(item.paths.join(" | ") || "nu există în structură")}</div>
                            <div class="files">${fileRows}</div>
                        </div>
                        <div class="side">
                            <div class="shelf-badge">${item.shelf !== "?" ? `Raft ${escapeHtml(item.shelf)}` : "Nu are raft"}</div>
                            <div class="muted">${item.shelf !== "?" ? "din configurare" : ""}</div>
                        </div>
                    </article>
                `;
            }).join("");
        }

        window.addEventListener("load", loadFromFile);
    </script>
</body>
